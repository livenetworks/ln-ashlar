{
	"name": "ln-acme",
	"version": "1.2.0",
	"description": "LiveNetworks unified frontend library — CSS framework and vanilla JS components",
	"type": "module",
	"main": "dist/ln-acme.js",
	"style": "dist/ln-acme.css",
	"files": [
		"dist/",
		"scss/",
		"js/"
	],
	"exports": {
		".": {
			"import": "./dist/ln-acme.js",
			"style": "./dist/ln-acme.css"
		},
		"./css": "./dist/ln-acme.css",
		"./js": "./dist/ln-acme.js",
		"./scss/*": "./scss/*",
		"./js/*": "./js/*"
	},
	"scripts": {
		"dev": "vite build --watch",
		"build": "vite build && npm run build:demos",
		"build:demos": "npm run build:demo-index && npm run build:demo-admin && npm run build:demo-docuflow",
		"build:demo-index": "sass demo/index.scss demo/index.css --no-source-map --style=compressed",
		"build:demo-admin": "sass demo/admin/src/admin.scss demo/admin/dist/admin.css --no-source-map --style=compressed && cp demo/admin/src/demo.js demo/admin/dist/demo.js",
		"build:demo-docuflow": "sass demo/docuflow/docuflow.scss demo/docuflow/dist/docuflow.css --no-source-map --style=compressed"
	},
	"devDependencies": {
		"@tabler/icons": "^3.41.1",
		"flag-icons": "^7.5.0",
		"sass-embedded": "^1.83.0",
		"vite": "^6.0.0"
	},
	"peerDependencies": {
		"tom-select": "^2.0.0"
	},
	"peerDependenciesMeta": {
		"tom-select": {
			"optional": true
		}
	},
	"license": "UNLICENSED",
	"private": true
}
